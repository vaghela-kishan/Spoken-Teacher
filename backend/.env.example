# ---- App ----
PROJECT_NAME=AI English Speaking Tutor
ENVIRONMENT=development
SECRET_KEY=change-me-super-secret-key-min-32-chars-long
API_V1_PREFIX=/api/v1

# ---- Auth ----
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Database ----
# Default = SQLite: zero setup, runs instantly. Great for trying the project.
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# For a real Postgres instead, comment the line above and use:
# DATABASE_URL=postgresql+asyncpg://tutor:tutor@localhost:5432/ai_english_tutor

# ---- Redis (optional) ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ---- AI ----
# Which LLM writes tutor replies: groq (fastest, free) | gemini | auto
LLM_PROVIDER=auto
GROQ_API_KEY=                    # free key: https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
WHISPER_MODEL=base
TTS_ENGINE=browser
PIPER_VOICE=en_US-amy-medium

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AI English Tutor <no-reply@ai-tutor.app>

# ---- Bootstrap admin (created by seed script) ----
FIRST_ADMIN_EMAIL=admin@ai-tutor.app
FIRST_ADMIN_PASSWORD=Admin@12345
