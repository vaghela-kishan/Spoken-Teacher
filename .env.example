# ============================================================
#  Root .env — consumed by docker-compose for the full stack
# ============================================================

# ---- Postgres ----
POSTGRES_USER=tutor
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=ai_english_tutor
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Backend ----
BACKEND_PORT=8000
SECRET_KEY=change-me-super-secret-key-min-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# ---- AI ----
# Which LLM writes the tutor replies: groq (fast) | gemini | auto
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key            # https://console.groq.com/keys  (fast primary)
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-google-gemini-api-key # fallback provider
GEMINI_MODEL=gemini-flash-latest
WHISPER_MODEL=base            # tiny | base | small | medium | large-v3
TTS_ENGINE=piper              # piper | kokoro | browser
PIPER_VOICE=en_US-amy-medium

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=AI English Tutor <no-reply@ai-tutor.app>

# ---- Frontend ----
# Baked into the static bundle at build time.
#   • Local/dev compose: point at the backend (values below).
#   • Production (NGINX edge, docker-compose.prod.yml): leave BOTH BLANK so the
#     browser calls the same origin and NGINX routes /api and /ws internally.
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ---- URLs used in emails / CORS ----
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
